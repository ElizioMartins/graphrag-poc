{
  "name": "graphrag-poc",
  "version": "1.0.0",
  "description": "POC de sistema RAG com GraphRAG usando Node.js, LangChain.js e Neo4j",
  "main": "src/api/server.ts",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "node --env-file .env --experimental-strip-types src/api/server.ts",
    "dev": "node --no-warnings --env-file .env --watch --experimental-strip-types src/api/server.ts",
    "infra:up": "docker-compose up -d --wait",
    "infra:down": "docker-compose down --volumes",
    "init:db": "node --env-file .env --experimental-strip-types src/scripts/initDatabase.ts",
    "clear:db": "node --env-file .env --experimental-strip-types src/scripts/clearDatabase.ts"
  },
  "keywords": [
    "rag",
    "graphrag",
    "langchain",
    "neo4j",
    "ai",
    "embeddings",
    "pdf",
    "xml"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@huggingface/inference": "^4.13.5",
    "@huggingface/transformers": "^3.8.1",
    "@langchain/community": "^0.3.59",
    "@langchain/core": "^0.3.80",
    "@langchain/openai": "^0.4.2",
    "@xenova/transformers": "^2.17.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "langchain": "^0.3.6",
    "multer": "^1.4.5-lts.1",
    "neo4j-driver": "^5.28.0",
    "pdf-parse": "^1.1.1",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.0.0",
    "@types/xml2js": "^0.4.14"
  }
}
