# Configurações do Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Configurações do OpenRouter (LLM)
OPENROUTER_API_KEY=sk-or-v1-YOUR_OPENROUTER_API_KEY_HERE
NLP_MODEL=nvidia/nemotron-3-super:free
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=GraphRAG POC

# Configurações de Embedding
# Modelo padrão: Xenova/all-MiniLM-L6-v2 (~90MB, 384 dimensões)
# Alternativas mais leves: Xenova/paraphrase-MiniLM-L3-v2 (~60MB)
# Na primeira execução, o modelo será baixado automaticamente do HuggingFace
# Para evitar timeout, execute: npm run download:model
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2

# Configurações do Servidor
PORT=3000

# Configurações de Upload
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=./uploads
