# Configurações do Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Configurações do OpenRouter (LLM)
OPENROUTER_API_KEY=sk-or-v1-YOUR_OPENROUTER_API_KEY_HERE

# Sistema de Fallback Automático para Modelos LLM
# O sistema tentará cada modelo na ordem. Se um falhar (404, rate limit, erro),
# automaticamente tenta o próximo da lista.
QTD_DE_NPL_MODEL=3
NLP_MODEL_1=google/gemma-4-26b-a4b-it:free                       # RECOMENDADO (melhor qualidade)
NLP_MODEL_2=minimax/minimax-m2.5:free                            # MiniMax (backup 1)
NLP_MODEL_3=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free   # NVIDIA (backup 2)

OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=GraphRAG POC

# Configurações de Embedding
# Modelo padrão: Xenova/all-MiniLM-L6-v2 (~90MB, 384 dimensões)
# Alternativas mais leves: Xenova/paraphrase-MiniLM-L3-v2 (~60MB)
# Na primeira execução, o modelo será baixado automaticamente do HuggingFace
# Para evitar timeout, execute: npm run download:model
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2

# Configurações do Servidor
PORT=3000

# Configurações de Upload
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=./uploads
